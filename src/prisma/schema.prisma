// Worklynk Prisma Schema
// Updated for strict "Save only after verification" flow

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  ADMIN
  CLIENT
  FREELANCER
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum DocumentType {
  PAN
  VAT
}

enum ProjectStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BudgetType {
  FIXED
  HOURLY
}

enum ExperienceLevel {
  ENTRY
  INTERMEDIATE
  EXPERT
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  REJECTED
  ACCEPTED
}

// ─── User Model ──────────────────────────────────────────
// Only verified users are stored here
model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  password      String
  phoneNumber   String?
  role          UserRole      @default(FREELANCER)
  status        AccountStatus @default(ACTIVE)
  lastLoginAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sessions      Session[]
  profile       Profile?
  projects      Project[]     @relation("ClientProjects")
  applications  Application[] @relation("FreelancerApplications")

  @@map("users")
}

// ─── Pending User Model ──────────────────────────────────
// Temporary storage for users who haven't verified their email yet
model PendingUser {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phoneNumber String?
  role      UserRole @default(CLIENT)
  otpCode   String   // Hashed OTP
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@map("pending_users")
}

// ─── Session Model ───────────────────────────────────────
model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}
// ─── Password Reset Model ────────────────────────────────
model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  code      String   // Hashed code
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_resets")
}

// ─── Profile Model ───────────────────────────────────────
// Stores user profile, bio, and verification details (PAN/VAT)
model Profile {
  id              String             @id @default(uuid())
  userId          String             @unique
  profilePicture  String?
  description     String?
  panVatNumber    String?
  documentType    DocumentType?      // newly added: PAN or VAT
  documentImage   String?            // URL/path to PAN/VAT document image
  verificationStatus VerificationStatus @default(UNVERIFIED)
  rejectionReason String?

  // Freelancer specific fields
  headline        String?
  skills          String[]
  education       Json?
  experience      Json?
  portfolio       Json?
  certifications  Json?
  hourlyRate      Float?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ─── Project Model ───────────────────────────────────────
model Project {
  id              String          @id @default(uuid())
  clientId        String
  title           String
  description     String
  category        String
  budgetType      BudgetType      @default(FIXED)
  budgetMin       Float?
  budgetMax       Float?
  skillsRequired  String[]
  experienceLevel ExperienceLevel @default(INTERMEDIATE)
  duration        String?
  attachments     Json?           // Array of { name, url, type }
  checklist       Json?           // Array of strings
  status          ProjectStatus   @default(DRAFT)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  client          User            @relation("ClientProjects", fields: [clientId], references: [id], onDelete: Cascade)
  applications    Application[]

  @@map("projects")
}

// ─── Application Model ───────────────────────────────────
model Application {
  id                String            @id @default(uuid())
  projectId         String
  freelancerId      String
  proposal          String
  bidAmount         Float
  estimatedDuration String
  attachments       Json?             // Array of { name, url, type }
  status            ApplicationStatus @default(PENDING)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  freelancer        User              @relation("FreelancerApplications", fields: [freelancerId], references: [id], onDelete: Cascade)

  @@unique([projectId, freelancerId]) // One application per project per freelancer
  @@map("applications")
}
