// Worklynk Prisma Schema
// Updated for strict "Save only after verification" flow

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  ADMIN
  CLIENT
  FREELANCER
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

// ─── User Model ──────────────────────────────────────────
// Only verified users are stored here
model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  password      String
  phoneNumber   String?
  role          UserRole      @default(FREELANCER)
  status        AccountStatus @default(ACTIVE)
  lastLoginAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sessions      Session[]

  @@map("users")
}

// ─── Pending User Model ──────────────────────────────────
// Temporary storage for users who haven't verified their email yet
model PendingUser {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phoneNumber String?
  role      UserRole @default(CLIENT)
  otpCode   String   // Hashed OTP
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@map("pending_users")
}

// ─── Session Model ───────────────────────────────────────
model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}
// ─── Password Reset Model ────────────────────────────────
model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  code      String   // Hashed code
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_resets")
}
