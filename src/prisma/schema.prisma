// Worklynk Prisma Schema
// Updated for strict "Save only after verification" flow

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  ADMIN
  CLIENT
  FREELANCER
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum DocumentType {
  PAN
  VAT
}

enum ProjectStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BudgetType {
  FIXED
  HOURLY
}

enum ExperienceLevel {
  ENTRY
  INTERMEDIATE
  EXPERT
}

enum ApplicationStatus {
  DRAFT
  PENDING
  SHORTLISTED
  REJECTED
  ACCEPTED
}

enum ContractStatus {
  DRAFT
  PENDING_FREELANCER
  ACTIVE
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum MilestoneStatus {
  PENDING
  IN_REVIEW
  PAID
  CANCELLED
}

// ─── User Model ──────────────────────────────────────────
// Only verified users are stored here
model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  password      String
  phoneNumber   String?
  role          UserRole      @default(FREELANCER)
  status        AccountStatus @default(ACTIVE)
  lastLoginAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sessions      Session[]
  profile       Profile?
  projects      Project[]     @relation("ClientProjects")
  applications  Application[] @relation("FreelancerApplications")
  contractsAsClient     Contract[] @relation("ClientContracts")
  contractsAsFreelancer Contract[] @relation("FreelancerContracts")

  // Bookmarking Relations
  savedProjects       SavedProject[] @relation("UserSavedProjects")
  savedFreelancers    SavedFreelancer[] @relation("ClientSavedFreelancers")
  savedByClients      SavedFreelancer[] @relation("FreelancerSavedByClients")

  @@map("users")
}

// ─── Pending User Model ──────────────────────────────────
// Temporary storage for users who haven't verified their email yet
model PendingUser {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phoneNumber String?
  role      UserRole @default(CLIENT)
  otpCode   String   // Hashed OTP
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@map("pending_users")
}

// ─── Session Model ───────────────────────────────────────
model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}
// ─── Password Reset Model ────────────────────────────────
model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  code      String   // Hashed code
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_resets")
}

// ─── Profile Model ───────────────────────────────────────
// Stores user profile, bio, and verification details (PAN/VAT)
model Profile {
  id              String             @id @default(uuid())
  userId          String             @unique
  profilePicture  String?
  description     String?
  panVatNumber    String?
  documentType    DocumentType?      // newly added: PAN or VAT
  documentImage   String?            // URL/path to PAN/VAT document image
  verificationStatus VerificationStatus @default(UNVERIFIED)
  rejectionReason String?

  // Freelancer specific fields
  headline        String?
  skills          String[]
  education       Json?
  experience      Json?
  portfolio       Json?
  certifications  Json?
  hourlyRate      Float?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ─── Project Model ───────────────────────────────────────
model Project {
  id              String          @id @default(uuid())
  clientId        String
  title           String
  description     String
  category        String
  budgetType      BudgetType      @default(FIXED)
  budgetMin       Float?
  budgetMax       Float?
  skillsRequired  String[]
  experienceLevel ExperienceLevel @default(INTERMEDIATE)
  duration        String?
  attachments     Json?           // Array of { name, url, type }
  checklist       Json?           // Array of strings
  status          ProjectStatus   @default(DRAFT)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  client          User            @relation("ClientProjects", fields: [clientId], references: [id], onDelete: Cascade)
  applications    Application[]
  contracts       Contract[]
  savedBy         SavedProject[]

  @@map("projects")
}

// ─── Application Model ───────────────────────────────────
model Application {
  id                String            @id @default(uuid())
  projectId         String
  freelancerId      String
  proposal          String
  bidAmount         Float
  estimatedDuration String
  attachments       Json?             // Array of { name, url, type }
  status            ApplicationStatus @default(PENDING)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  freelancer        User              @relation("FreelancerApplications", fields: [freelancerId], references: [id], onDelete: Cascade)
  contract          Contract?

  @@unique([projectId, freelancerId]) // One application per project per freelancer
  @@map("applications")
}

// ─── Bookmarking System ──────────────────────────────────
model SavedProject {
  id          String   @id @default(uuid())
  userId      String
  projectId   String
  createdAt   DateTime @default(now())

  user        User     @relation("UserSavedProjects", fields: [userId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("saved_projects")
}

model SavedFreelancer {
  id            String   @id @default(uuid())
  clientId      String
  freelancerId  String
  createdAt     DateTime @default(now())

  client        User     @relation("ClientSavedFreelancers", fields: [clientId], references: [id], onDelete: Cascade)
  freelancer    User     @relation("FreelancerSavedByClients", fields: [freelancerId], references: [id], onDelete: Cascade)

  @@unique([clientId, freelancerId])
  @@map("saved_freelancers")
}

// ─── Contract & Kanban System ─────────────────────────────
model Contract {
  id              String         @id @default(uuid())
  projectId       String
  clientId        String
  freelancerId    String
  applicationId   String         @unique
  title           String
  description     String?
  status          ContractStatus @default(DRAFT)
  totalAmount     Float
  paidAmount      Float          @default(0)
  remarks         String?        // Freelancer's rejection remarks
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client          User           @relation("ClientContracts", fields: [clientId], references: [id], onDelete: Cascade)
  freelancer      User           @relation("FreelancerContracts", fields: [freelancerId], references: [id], onDelete: Cascade)
  application     Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  milestones      Milestone[]
  tasks           Task[]
  boardColumns    BoardColumn[]
  review          Review?

  @@map("contracts")
}

model BoardColumn {
  id              String   @id @default(uuid())
  contractId      String
  milestoneId     String?
  name            String
  color           String?  @default("slate")
  clientFeedback  String?
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  milestone       Milestone? @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  tasks           Task[]
  feedbacks       ColumnFeedback[]

  @@map("board_columns")
}

model ColumnFeedback {
  id              String   @id @default(uuid())
  columnId        String
  content         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  column          BoardColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@map("column_feedbacks")
}

model Milestone {
  id              String          @id @default(uuid())
  contractId      String
  title           String
  description     String?
  amount          Float
  status          MilestoneStatus @default(PENDING)
  clientFeedback  String?
  freelancerNotes String?
  dueDate         DateTime?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  contract        Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  boardColumns    BoardColumn[]
  tasks           Task[]

  @@map("milestones")
}

model Task {
  id              String   @id @default(uuid())
  contractId      String
  milestoneId     String?
  columnId        String?
  title           String
  description     String?
  status          String   @default("TODO") // Legacy field, keeping for compatibility if needed, but columnId is primary
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contract        Contract     @relation(fields: [contractId], references: [id], onDelete: Cascade)
  milestone       Milestone?   @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  column          BoardColumn? @relation(fields: [columnId], references: [id], onDelete: SetNull)
  feedbacks       TaskFeedback[]

  @@map("tasks")
}

model TaskFeedback {
  id              String   @id @default(uuid())
  taskId          String
  content         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_feedbacks")
}

// ─── Review Model ─────────────────────────────────────────
model Review {
  id              String   @id @default(uuid())
  contractId      String   @unique
  reviewerId      String
  revieweeId      String
  rating          Int      // 1-5
  comment         String?
  createdAt       DateTime @default(now())

  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  @@map("reviews")
}
